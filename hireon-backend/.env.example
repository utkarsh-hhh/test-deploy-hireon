# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=HireOn
APP_ENV=development          # development | production
SECRET_KEY=change-me-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:root@localhost:5432/hireon_db

# ── Google Gemini AI (FREE) ───────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Leave blank to use console fallback (prints email to terminal)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password     # Google Account → Security → App Passwords
SMTP_FROM_NAME=HireOn

# ── Google Calendar (optional) ────────────────────────────────────────────────
# Leave blank to use fake Meet link fallback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/calendar/callback

# ── Storage (local filesystem) ────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
